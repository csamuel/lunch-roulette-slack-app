{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter lunch-roulette-web run build",
  "outputDirectory": "packages/web/dist",
  "functions": {
    "packages/api/**/*": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/packages/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
