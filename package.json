{
  "name": "lunch-roulette",
  "version": "1.0.0",
  "description": "A Slack app that randomly picks a lunch spot within walking distance.",
  "main": "api/slack/lunchr.ts",
  "scripts": {
    "build": "tsc",
    "start": "vercel dev",
    "deploy": "vercel --prod",
    "format:check": "prettier ./api --check",
